{
  "manifest_version": 3,
  "name": "Simulador de Datos",
  "version": "1.0",
  "description": "Autocompleta formularios con datos ficticios.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["faker.min.js", "content.js"]
    }
  ]
}
